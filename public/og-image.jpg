<svg width="1200" height="630" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0A0A0F;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#111118;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="accentGradient" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#00D4FF;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#7B61FF;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bgGradient)"/>
  <rect x="0" y="0" width="1200" height="630" fill="url(#accentGradient)" opacity="0.1"/>

  <!-- Decorative elements -->
  <circle cx="100" cy="100" r="200" fill="#00D4FF" opacity="0.05"/>
  <circle cx="1100" cy="530" r="250" fill="#7B61FF" opacity="0.05"/>

  <!-- Main content -->
  <text x="600" y="280" font-family="Arial, sans-serif" font-size="72" font-weight="bold" fill="#F0F0F8" text-anchor="middle">
    Abbas Rasool
  </text>
  <text x="600" y="360" font-family="Arial, sans-serif" font-size="28" fill="#9090A8" text-anchor="middle">
    Crystal Reports Developer | SQL Server Specialist
  </text>
  <text x="600" y="400" font-family="Arial, sans-serif" font-size="20" fill="#5A5A72" text-anchor="middle">
    2+ Years Experience • Available for Freelance Projects
  </text>

  <!-- Tech stack badges -->
  <rect x="450" y="440" width="300" height="40" rx="20" fill="#1A1A24" stroke="#2A2A38" stroke-width="2"/>
  <text x="600" y="466" font-family="Arial, sans-serif" font-size="16" fill="#00D4FF" text-anchor="middle">
    Crystal Reports • SQL Server • VB6 • Next.js
  </text>
</svg>
